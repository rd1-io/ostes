---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---
<Base title="Запись на приём — ОстеоКлиник" description="Запишитесь на приём к врачу ОстеоКлиник в Бресте онлайн.">
  <section class="page-hero">
    <div class="container">
      <Breadcrumbs items={[
        { label: 'Главная', href: '/' },
        { label: 'Запись на приём' },
      ]} />
      <h1 class="page-title">Запись на приём</h1>
      <p class="page-subtitle">Заполните форму — администратор свяжется с вами для подтверждения времени. Или позвоните: +375 29 805-02-02.</p>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container" style="max-width: 640px;">
      <div class="content-block">
        <form class="form" data-booking-form action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
          <div class="form-row">
            <div class="field">
              <label for="name">Ваше имя</label>
              <input type="text" id="name" name="name" required placeholder="Иван Иванов" />
            </div>
            <div class="field">
              <label for="phone">Телефон *</label>
              <input type="tel" id="phone" name="phone" required placeholder="+375 29 ___-__-__" />
            </div>
          </div>
          <div class="field">
            <label for="email">Email (необязательно)</label>
            <input type="email" id="email" name="email" placeholder="ivan@example.com" />
          </div>
          <div class="field">
            <label for="service">Направление</label>
            <select id="service" name="service">
              <option value="">Не знаю / помогите выбрать</option>
              {services.map((s) => (
                <option value={s.data.title}>{s.data.title}</option>
              ))}
            </select>
          </div>
          <div class="field">
            <label for="message">Комментарий (необязательно)</label>
            <textarea id="message" name="message" rows="3" placeholder="Опишите симптомы или пожелания по времени"></textarea>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn-primary btn-lg">Отправить заявку</button>
          </div>
          <div class="form-message"></div>
          <p class="form-hint">
            <!-- Заменить YOUR_FORM_ID на реальный Formspree ID -->
            * Нажимая кнопку, вы соглашаетесь на обработку персональных данных.
          </p>
        </form>
      </div>
    </div>
  </section>
</Base>

---
import Base from '../layouts/Base.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { getCollection } from 'astro:content';

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
---
<Base title="ОстеоКлиник — частная медицинская клиника в Бресте" preloadImage="/images/hero/slide-1.webp">
  <section class="hero-carousel">
    <div class="carousel-track">
      <div class="carousel-slide" style="background-image: url('/images/hero/slide-1.webp')">
        <div class="carousel-overlay">
          <div class="container hero-inner">
            <h2 class="hero-title">
              Комплексный подход к<br />
              <span class="hero-highlight">здоровью позвоночника, сосудов и сердца</span>
            </h2>
            <p class="hero-text">
              Неврология, УЗИ диагностика, хирургия, кардиология и флебология в одном месте.
              Работаем по записи, без очередей, с внимательным отношением к каждому пациенту.
            </p>
            <div class="hero-actions">
              <a href="/booking" class="btn-primary btn-lg">Записаться на приём</a>
              <a href="tel:+375336472014" class="btn-outline btn-lg">Позвонить</a>
            </div>
          </div>
        </div>
      </div>
      <div class="carousel-slide" style="background-image: url('/images/hero/slide-2.webp')">
        <div class="carousel-overlay">
          <div class="container hero-inner">
            <h2 class="hero-title">
              <span class="hero-highlight">Неврология</span> — найдём причину боли
            </h2>
            <p class="hero-text">
              Головные боли, остеохондроз, онемение конечностей, головокружения.
              Опытный невролог проведёт диагностику и составит план лечения.
            </p>
            <div class="hero-actions">
              <a href="/services/neurology" class="btn-primary btn-lg">Подробнее</a>
              <a href="/booking" class="btn-outline btn-lg">Записаться</a>
            </div>
          </div>
        </div>
      </div>
      <div class="carousel-slide" style="background-image: url('/images/hero/slide-3.webp')">
        <div class="carousel-overlay">
          <div class="container hero-inner">
            <h2 class="hero-title">
              <span class="hero-highlight">УЗИ диагностика</span> на экспертном оборудовании
            </h2>
            <p class="hero-text">
              Органы брюшной полости, щитовидная железа, сосуды, суставы, эхокардиография.
              Результаты сразу после исследования.
            </p>
            <div class="hero-actions">
              <a href="/services/ultrasound" class="btn-primary btn-lg">Подробнее</a>
              <a href="/booking" class="btn-outline btn-lg">Записаться</a>
            </div>
          </div>
        </div>
      </div>
      <div class="carousel-slide" style="background-image: url('/images/hero/slide-4.webp')">
        <div class="carousel-overlay">
          <div class="container hero-inner">
            <h2 class="hero-title">
              <span class="hero-highlight">Кардиология и флебология</span> — забота о сосудах и сердце
            </h2>
            <p class="hero-text">
              ЭКГ, эхокардиография, дуплексное сканирование вен, склеротерапия.
              Современная диагностика и лечение в одной клинике.
            </p>
            <div class="hero-actions">
              <a href="/services/cardiology" class="btn-primary btn-lg">Кардиология</a>
              <a href="/services/phlebology" class="btn-outline btn-lg">Флебология</a>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="carousel-dots">
      <button class="carousel-dot is-active" aria-label="Слайд 1"></button>
      <button class="carousel-dot" aria-label="Слайд 2"></button>
      <button class="carousel-dot" aria-label="Слайд 3"></button>
      <button class="carousel-dot" aria-label="Слайд 4"></button>
    </div>
  </section>

  <section class="features-strip">
    <div class="container">
      <div class="features-row">
        <div class="feature-item">
          <strong>Опытные врачи</strong>
          <span>Специалисты с многолетним стажем</span>
        </div>
        <div class="feature-item">
          <strong>Современное УЗИ</strong>
          <span>Диагностика на месте, без очередей</span>
        </div>
        <div class="feature-item">
          <strong>Удобная запись</strong>
          <span>Онлайн, по звонку или в мессенджере</span>
        </div>
        <div class="feature-item">
          <strong>Внимание к пациенту</strong>
          <span>Понятный план лечения и наблюдения</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-header">
        <div class="section-eyebrow">Направления</div>
        <h2 class="section-title">Основные услуги ОстеоКлиник</h2>
        <p class="section-description">
          Если вы не уверены, к какому специалисту записаться, просто опишите свои жалобы в заявке — мы поможем
          подобрать подходящее направление.
        </p>
      </header>
      <div class="grid-cards">
        {services.map((s) => (
          <ServiceCard title={s.data.title} text={s.data.cardText} slug={s.data.slug} />
        ))}
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="container">
      <div class="cta-box">
        <div class="cta-text">
          <h2>Нужна консультация врача в ближайшие дни?</h2>
          <p>Оставьте заявку онлайн — администратор свяжется с вами, уточнит симптомы и подберёт удобное время.</p>
        </div>
        <div class="cta-actions">
          <a href="/booking" class="btn-primary">Оставить заявку</a>
          <a href="tel:+375298050202" class="btn-cta-secondary">+375 29 805-02-02</a>
        </div>
      </div>
    </div>
  </section>
</Base>

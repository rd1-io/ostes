---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BookingCta from '../../components/BookingCta.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const doctors = await getCollection('doctors');
  return doctors.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { name, role, category, experience, image, tags, manipulations, training } = entry.data;
const hasExperience = experience && experience !== '—';

const trainingByYear = training.reduce((acc, item) => {
  (acc[item.year] ??= []).push(item.title);
  return acc;
}, {} as Record<string, string[]>);

const trainingYears = Object.keys(trainingByYear).sort((a, b) => {
  const na = parseInt(a, 10);
  const nb = parseInt(b, 10);
  if (isNaN(na)) return 1;
  if (isNaN(nb)) return -1;
  return nb - na;
});
---
<Base title={`${name} — ОстеоКлиник`} description={`${role}. ${hasExperience ? `Стаж: ${experience}. ` : ''}Запись на приём в ОстеоКлиник, Брест.`}>
  <section class="page-hero">
    <div class="container">
      <Breadcrumbs items={[
        { label: 'Главная', href: '/' },
        { label: 'Врачи', href: '/doctors' },
        { label: name },
      ]} />
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="doctor-profile">
        <div class="doctor-profile-photo">
          {image
            ? <img src={image} alt={name} />
            : <div class="doctor-photo-placeholder">{name.charAt(0)}</div>}
        </div>
        <div class="doctor-profile-body">
          <h1 class="doctor-profile-name">{name}</h1>
          <p class="doctor-profile-role">{role}</p>
          <div class="doctor-profile-meta">
            {category && <span class="doctor-meta-chip">Категория: {category}</span>}
            {hasExperience && <span class="doctor-meta-chip">Стаж: {experience}</span>}
          </div>
          {tags.length > 0 && (
            <div class="doctor-profile-tags">
              {tags.map((tag) => <span class="doctor-tag">{tag}</span>)}
            </div>
          )}
          <div class="doctor-profile-actions">
            <a href="/booking" class="btn-primary">Записаться на приём</a>
          </div>
        </div>
      </div>

      <div class="doctor-content">
        <div class="doctor-content-main">
          <div class="doctor-about">
            <Content />
          </div>

          {manipulations.length > 0 && (
            <div class="info-card">
              <h2>Манипуляции и услуги</h2>
              <ul class="doctor-manipulations">
                {manipulations.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          )}
        </div>

        {training.length > 0 && (
          <aside class="doctor-content-side">
            <div class="info-card">
              <h2>Повышение квалификации<br />и конференции</h2>
              <div class="doctor-training">
                {trainingYears.map((year) => (
                  <div class="doctor-training-group">
                    <div class="doctor-training-year">{year}</div>
                    <ul class="doctor-training-list">
                      {trainingByYear[year].map((title) => <li>{title}</li>)}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
          </aside>
        )}
      </div>

      <BookingCta text={`Записаться на приём — ${name}`} />
    </div>
  </section>
</Base>

---
interface Props {
  name: string;
  role: string;
  experience: string;
  tags: string[];
  image?: string;
  href: string;
}
const { name, role, experience, tags, image, href } = Astro.props;
---
<a class="doctor-card" href={href}>
  <div class="doctor-photo">
    {image
      ? <img src={image} alt={name} />
      : <span class="doctor-photo-initial">{name.charAt(0)}</span>}
  </div>
  <div class="doctor-name">{name}</div>
  <div class="doctor-role">{role}</div>
  <div class="doctor-exp">Стаж: {experience}</div>
  <div class="doctor-tags">
    {tags.map((tag) => <span class="doctor-tag">{tag}</span>)}
  </div>
</a>

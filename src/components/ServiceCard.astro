---
interface Props {
  title: string;
  text: string;
  slug: string;
}
const { title, text, slug } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<article class="card">
  <h3 class="card-title">{title}</h3>
  <p class="card-text">{text}</p>
  <a href={`${base}services/${slug}`} class="card-link">Подробнее →</a>
</article>
